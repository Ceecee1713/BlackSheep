  ButtonOneText: Black
  ButtonTwoText: White
  NormalDialogue:
  - CharacterTitle: 1
    Message: So you chose to shoot a sheep on round one
  - CharacterTitle: 1
    Message: 'Bold of you to do that. '
  - CharacterTitle: 1
    Message: Amuse my curiosity. What colour do you like more?
  ButtonOneDialogue:
  - CharacterTitle: 1
    Message: 'Black. '
  - CharacterTitle: 1
    Message: Black is nothingness. Emptiness. Devoid of anything.
  - CharacterTitle: 1
    Message: But because of that emptiness, it can be anything, becaue it starts
      off as nothing
  - CharacterTitle: 1
    Message: Let's continue with the game
  ButtonTwoDialogue:
  - CharacterTitle: 1
    Message: White.
  - CharacterTitle: 1
    Message: White is purity
  - CharacterTitle: 1
    Message: It's easy to tell when something is tainted as white exposes all dirt
      and lies
  - CharacterTitle: 1
    Message: Interesting
  - CharacterTitle: 1
    Message: Let's continue with the game
