  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Each round, you'll start with four cards.\n\nThere are five card types
    you can get: Sheep, Dealer, Player, Gun, Spades\n\nSheep, Dealer and Player cards,
    are considered \"Person Cards\" \n\nTo progress into the next round, you have
    to place one Person Card, and one gun card down in the card slots on the table.\n\nThe
    goal is to shoot a person at the end of each round, and the Person Card placed
    down will be that person you shoot at the end of the round.\n\nSpades cards hold
    no value and can't be placed down.\n\nIf you don't like your hand, you can reshuffle
    for a max of three times per round. You can't ask for a reshuffle when a card
    is played.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
